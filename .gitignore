# ─── Project artefacts (large or regenerable) ───────────────────────────────
# Raw + processed datasets and engineered feature matrices: too large for git
# and reproducible from the original RACE dataset and the preprocessing code.
data/raw/
data/processed/
data/features/
data/embeddings/

# Trained model checkpoints: regenerable by re running model_a.py and
# model_a_neural.py. Keeping them out of git keeps the repository light.
models/*.pkl
models/*.npz
*.npy
*.pt
*.pth
*.bin

